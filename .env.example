# =============================================================================
# Libertad Capital - Environment Variables
# Copy this content to a new .env file and fill in your credentials
# DO NOT commit .env to git - it contains secrets
# =============================================================================

# GoHighLevel API
# Get from: Settings > Private Integrations > Create new Integration
# Scopes needed: contacts/all, campaigns/read, opportunities/all
GOHIGHLEVEL_API_KEY=your_ghl_private_integration_token_here
GOHIGHLEVEL_LOCATION_ID=your_ghl_location_id_here

# Zoho API (for Zoho Campaigns bounce data)
# Get from: Zoho Developer Console > Your App > Client Credentials
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here

# Google Sheets
# Place credentials.json in the project root (from Google Cloud Console)
GOOGLE_CREDENTIALS=credentials.json
SPREADSHEET_ID=your_google_sheet_id_here
SHEET_NAME=Suppression Register

# Run mode - set to true to test without writing to sheets
DRY_RUN=false
